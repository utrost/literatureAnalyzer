            "type": "array"
          },
          "name": {
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "name",
          "beats"
        ],
        "title": "Shape",
        "type": "object"
      },
      "ShapeBeat": {
        "properties": {
          "function": {
            "title": "Function",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "valence": {
            "maximum": 1.0,
            "minimum": -1.0,
            "title": "Valence",
            "type": "number"
          },
          "weight": {
            "default": 1.0,
            "exclusiveMinimum": 0.0,
            "title": "Weight",
            "type": "number"
          }
        },
        "required": [
          "id",
          "valence",
          "function"
        ],
        "title": "ShapeBeat",
        "type": "object"
      }
    },
    "$ref": "#/$defs/Shape"
  },
  "StyleProfile": {
    "$defs": {
      "StyleAxes": {
        "properties": {
          "description_density": {
            "enum": [
              "sparse",
              "medium",
              "lush"
            ],
            "title": "Description Density",
            "type": "string"
          },
          "dialogue_attribution": {
            "enum": [
              "minimal",
              "conventional",
              "elaborate"
            ],
            "title": "Dialogue Attribution",
            "type": "string"
          },
          "diction_register": {
            "enum": [
              "formal",
              "colloquial",
              "archaic",
              "technical"
            ],
            "title": "Diction Register",
            "type": "string"
          },
          "latinate_ratio": {
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "title": "Latinate Ratio",
            "type": "string"
          },
          "psychic_distance": {
            "enum": [
              "far",
              "medium",
              "close"
            ],
            "title": "Psychic Distance",
            "type": "string"
          },
          "sentence_length_mean": {
            "title": "Sentence Length Mean",
            "type": "integer"
          },
          "sentence_length_variance": {
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "title": "Sentence Length Variance",
            "type": "string"
          },
          "show_tell_ratio": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Show Tell Ratio",
            "type": "number"
          }
        },
        "required": [
          "sentence_length_mean",
          "sentence_length_variance",
          "diction_register",
          "latinate_ratio",
          "psychic_distance",
          "show_tell_ratio",
          "description_density",
          "dialogue_attribution"
        ],
        "title": "StyleAxes",
        "type": "object"
      }
    },
    "properties": {
      "_meta": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Meta"
      },
      "authored_brief": {
        "title": "Authored Brief",
        "type": "string"
      },
      "axes": {
        "$ref": "#/$defs/StyleAxes"
      },
      "exemplars": {
        "items": {
          "type": "string"
        },
        "title": "Exemplars",
        "type": "array"
      },
      "id": {
        "title": "Id",
        "type": "string"
      },
      "name": {
        "title": "Name",
        "type": "string"
      }
    },
    "required": [
      "id",
      "name",
      "axes",
      "authored_brief"
    ],
    "title": "StyleProfile",
    "type": "object"
  },
