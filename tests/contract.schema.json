{
  "BeatPlan": {
    "$defs": {
      "Beat": {
        "properties": {
          "forbidden_events": {
            "items": {
              "type": "string"
            },
            "title": "Forbidden Events",
            "type": "array"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "mood": {
            "title": "Mood",
            "type": "string"
          },
          "pov": {
            "title": "Pov",
            "type": "string"
          },
          "rationale": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Rationale"
          },
          "required_events": {
            "items": {
              "type": "string"
            },
            "title": "Required Events",
            "type": "array"
          },
          "shape_function": {
            "title": "Shape Function",
            "type": "string"
          },
          "target_words": {
            "exclusiveMinimum": 0,
            "title": "Target Words",
            "type": "integer"
          },
          "tropes": {
            "items": {
              "type": "string"
            },
            "title": "Tropes",
            "type": "array"
          }
        },
        "required": [
          "id",
          "shape_function",
          "target_words",
          "pov",
          "required_events",
          "mood"
        ],
        "title": "Beat",
        "type": "object"
      },
      "Section": {
        "properties": {
          "beat_ids": {
            "items": {
              "type": "string"
            },
            "title": "Beat Ids",
            "type": "array"
          },
          "children": {
            "items": {
              "$ref": "#/$defs/Section"
            },
            "title": "Children",
            "type": "array"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "level": {
            "enum": [
              "book",
              "part",
              "chapter",
              "scene"
            ],
            "title": "Level",
            "type": "string"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Title"
          }
        },
        "required": [
          "id",
          "level"
        ],
        "title": "Section",
        "type": "object"
      }
    },
    "properties": {
      "_meta": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Meta"
      },
      "beats": {
        "items": {
          "$ref": "#/$defs/Beat"
        },
        "title": "Beats",
        "type": "array"
      },
      "structure": {
        "anyOf": [
          {
            "$ref": "#/$defs/Section"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      }
    },
    "required": [
      "beats"
    ],
    "title": "BeatPlan",
    "type": "object"
  },
  "Shape": {
    "$defs": {
      "Shape": {
        "properties": {
          "beats": {
            "items": {
              "$ref": "#/$defs/ShapeBeat"
            },
            "title": "Beats",
            "type": "array"
          },
          "children": {
            "items": {
              "$ref": "#/$defs/Shape"
